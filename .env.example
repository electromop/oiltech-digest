# PostgreSQL (Docker)
POSTGRES_USER=oiltech
POSTGRES_PASSWORD=change_me
POSTGRES_DB=oiltech_digest

# Строка подключения приложения (psycopg). Должна соответствовать переменным выше.
DATABASE_URL=postgresql://oiltech:change_me@localhost:5432/oiltech_digest

# OpenAI / ChatGPT API (AI-суть, тегирование, скоринг)
OPENAI_API_KEY=
# Основная модель для summary/tagging/scoring. На воркере, который реально зовёт OpenAI,
# ставьте минимум gpt-5-mini — gpt-5-nano слишком слаб и пропускает мусор в выборку.
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REASONING_EFFORT=minimal
OPENAI_TIMEOUT=60
# Гейт релевантности — критическая защита от нерелевантных новостей. Можно дать модель
# СИЛЬНЕЕ основной и больше reasoning (вызов дешёвый, цена ошибки высокая).
# Если пусто — откат на OPENAI_MODEL / 'medium'. ОБЯЗАТЕЛЬНО задавайте на воркере.
OPENAI_RELEVANCE_MODEL=gpt-5
OPENAI_RELEVANCE_REASONING=medium

# Переводчик заголовков — отдельная стадия пайплайна. Ответ короткий (один заголовок),
# по умолчанию хватает основной (дешёвой) модели. Если пусто — откат на OPENAI_MODEL /
# OPENAI_REASONING_EFFORT. AI дёргается ТОЛЬКО для иностранных заголовков (русские берутся как есть).
OPENAI_TRANSLATE_MODEL=
OPENAI_TRANSLATE_REASONING=

# USD за 1M токенов. Актуализируйте при смене модели/прайсинга.
OPENAI_INPUT_USD_PER_MTOK=0.05
OPENAI_OUTPUT_USD_PER_MTOK=0.40

# RSS discovery: короткий probe-таймаут, чтобы медленные сайты не подвешивали обход.
RSS_PROBE_TIMEOUT=4
HTTP_MIN_INTERVAL_SECONDS=1.5
HTTP_JITTER_SECONDS=0.4
HTTP_BLOCK_COOLDOWN_SECONDS=900
REQUEST_ARTICLE_LIMIT=6

# --- Прокси для парсинга (residential, напр. 2captcha) ---
# Если задан PROXY_URL — ВЕСЬ парсинг (RSS discovery, ленты, full-text) идёт через прокси.
# Пусто = прямые запросы (как при локальной разработке).
# На сервере заполнять глобально только если диагностика показала массовые IP-блоки.
# Формат 2captcha (HTTP-прокси с авторизацией, порт обычно 8080):
#   PROXY_URL=http://USER:PASS@HOST:8080
# OpenAI через прокси НЕ ходит (намеренно — у него отдельный клиент).
PROXY_URL=
# Точечный роутинг по доменам имеет приоритет над PROXY_URL.
# Формат: host=proxy_url,host2=proxy_url2
#   PROXY_HOST_OVERRIDES=rbc.ru=http://RU_USER:RU_PASS@RU_HOST:8080,shell.com=http://INTL_USER:INTL_PASS@INTL_HOST:8080
PROXY_HOST_OVERRIDES=
# Таймаут (сек) для запросов через прокси (residential медленнее прямого).
PROXY_TIMEOUT=40

# Docker scheduler. По умолчанию: цикл каждые 6 часов.
CYCLE_INTERVAL_SECONDS=21600
RUN_DISCOVER_ON_START=1
DISCOVER_EVERY_CYCLES=24
DISCOVER_TIMEOUT=4
DISCOVER_WORKERS=2
PARSE_WORKERS=3
FULL_TEXT_LIMIT=80
FULL_TEXT_MIN_CHARS=800
AI_PROCESS_LIMIT=50
AI_OFFLINE=0

# В docker-compose bootstrap выполняется отдельным сервисом.
# Для ручного запуска scheduler можно оставить 0, для compose это переопределяется в 1.
SKIP_BOOTSTRAP=0
